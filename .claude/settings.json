{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.staging)",
      "Read(.env.test)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/credential*)",
      "Read(**/private-key*)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.pub)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",

      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(.git/objects/**)",
      "Read(public/swagger/swagger-ui-bundle.js)",
      "Read(public/swagger/swagger-ui-bundle.js.map)",
      "Read(public/swagger/swagger-ui-standalone-preset.js)",
      "Read(public/swagger/swagger-ui-standalone-preset.js.map)",
      "Read(public/swagger/swagger-ui.js)",
      "Read(public/swagger/swagger-ui.js.map)",
      "Read(public/swagger/swagger-ui.css)",
      "Read(public/swagger/swagger-ui.css.map)",
      "Read(public/img/**)",
      "Read(logs/**)",

      "Grep(node_modules/**)",
      "Grep(dist/**)",
      "Grep(public/swagger/**)",
      "Grep(logs/**)",
      "Grep(.git/**)",

      "Glob(node_modules/**)",
      "Glob(dist/**)",
      "Glob(public/swagger/**)",
      "Glob(logs/**)",
      "Glob(.git/**)",

      "Write(.env)",
      "Write(.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.keystore)",
      "Write(**/*.jks)",
      "Write(**/id_rsa)",
      "Write(**/secrets/**)",
      "Write(**/credentials/**)",
      "Write(node_modules/**)",
      "Write(.git/**)",

      "Grep(**/.env*)",
      "Grep(**/*.pem)",
      "Grep(**/*.key)",
      "Grep(**/*.p12)",
      "Grep(**/*.keystore)",
      "Grep(**/id_rsa)",
      "Grep(**/secrets/**)",
      "Grep(**/credentials/**)",

      "Glob(**/.env*)",
      "Glob(**/*.pem)",
      "Glob(**/*.key)",
      "Glob(**/*.p12)",
      "Glob(**/*.keystore)",
      "Glob(**/id_rsa)",
      "Glob(**/secrets/**)",
      "Glob(**/credentials/**)",

      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(DROP TABLE*)",
      "Bash(DROP DATABASE*)",
      "Bash(format *)",
      "Bash(mkfs*)"
    ],
    "ask": [
      "Read(package-lock.json)",
      "Read(readme.md)",
      "Read(server/migrations/**)",
      "Read(.babelrc)",
      "Read(.eslintrc)",
      "Read(.eslintignore)",
      "Read(.prettierrc)",
      "Read(.prettierignore)",
      "Read(public/index.html)",
      "Read(public/swagger/index.html)",
      "Read(public/swagger/oauth2-redirect.html)"
    ],
    "allow": [
      "Read(client/**)",
      "Read(server/**)",
      "Read(webpack/**)",
      "Read(package.json)",
      "Read(knexfile.js)",
      "Read(.env.example)",
      "Read(CLAUDE.md)",
      "Read(.claude/**)",
      "Read(docs/**)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run build:prod)",
      "Bash(npm run webpack:dev)",
      "Bash(npm run webpack:prod)",
      "Bash(npm run migrate)",
      "Bash(npm run migrate:rollback)",
      "Bash(npm run migrate:make*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git show*)",
      "Bash(node -e \"JSON.parse*\")"
    ]
  }
}
